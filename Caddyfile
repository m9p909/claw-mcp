# Caddyfile for Claw MCP Server
# Provides TLS termination with support for both self-signed (dev) and Let's Encrypt (prod)
#
# Environment Variables:
#   DOMAIN         - Domain name for TLS certificate (default: localhost)
#   UPSTREAM       - Upstream Claw service address (default: claw:8080 for Docker, or localhost:8080 for VM)
#   TLS_MODE       - "self_signed" for dev, "letsencrypt" for production

{$DOMAIN:localhost} {
    # Reverse proxy to internal Claw service
    reverse_proxy {$UPSTREAM:localhost:8080}

    # TLS Configuration based on environment
    # For localhost (development): auto-generate self-signed certificates
    # For production domain: obtain from Let's Encrypt via ACME

    @self_signed {
        # Match self-signed mode (localhost development)
        expression `{env.TLS_MODE} == "self_signed"`
    }

    @letsencrypt {
        # Match Let's Encrypt mode (production)
        expression `{env.TLS_MODE} == "letsencrypt"`
    }

    # Self-signed certificate generation for development
    tls internal {
        on_demand
    }

    # Force HTTP to HTTPS redirect for all requests
    @http {
        protocol http
    }
    redir @http https://{host}{uri} permanent

    # Logging
    log {
        output stdout
        format json
    }
}
